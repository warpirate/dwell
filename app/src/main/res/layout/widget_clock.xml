<?xml version="1.0" encoding="utf-8"?>
<!-- Editorial clock: Fraunces hero time (bundled @font/fraunces), a short hairline,
     a single green accent dot, tracked-uppercase AA-muted date. RemoteViews-safe:
     no <View>, no downloadable font, static radius. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="start|center_vertical"
    android:background="@drawable/widget_bg"
    android:paddingHorizontal="22dp"
    android:paddingVertical="20dp">

    <TextClock
        android:id="@+id/widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/fraunces"
        android:includeFontPadding="false"
        android:format12Hour="h:mm"
        android:format24Hour="H:mm"
        android:letterSpacing="-0.01"
        android:textColor="#ECE7DD"
        android:textSize="56sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="13dp">

        <ImageView
            android:id="@+id/widget_rule"
            android:layout_width="46dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/widget_rule"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/widget_accent"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="9dp"
                android:src="@drawable/widget_dot"
                android:contentDescription="@null" />

            <TextClock
                android:id="@+id/widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true"
                android:letterSpacing="0.18"
                android:format12Hour="EEE, MMM d"
                android:format24Hour="EEE, MMM d"
                android:textColor="#A89F8E"
                android:textSize="11.5sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
