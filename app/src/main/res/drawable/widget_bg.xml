<?xml version="1.0" encoding="utf-8"?>
<!-- Editorial card: 3-stop warm gradient (bright top edge = hairline highlight,
     deep bottom = lift) + 1dp cream hairline stroke. No box-shadow (RemoteViews);
     depth lives in the gradient + stroke. Static 26dp radius. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="26dp" />
    <gradient
        android:angle="270"
        android:startColor="#322D26"
        android:centerColor="#221E18"
        android:endColor="#15110C"
        android:centerY="0.18" />
    <stroke android:width="1dp" android:color="#22ECE7DD" />
</shape>
